[Unit]
Description=CySA Atlas Velociraptor VQL HTTP Proxy
After=docker.service
Requires=docker.service

[Service]
ExecStart=/usr/bin/python3 /opt/CySA-config/velociraptor/vql_proxy.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
User=root

[Install]
WantedBy=multi-user.target
